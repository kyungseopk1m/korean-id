{
  "name": "korean-id",
  "version": "1.1.0",
  "description": "한국 식별번호 통합 검증 라이브러리 (BRN/RRN/CRN/FRN/PCC/DLN/Passport/VRN)",
  "main": "dist/cjs/index.js",
  "module": "dist/mjs/index.js",
  "types": "dist/mjs/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/mjs/index.d.ts",
        "default": "./dist/mjs/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "scripts": {
    "test": "jest",
    "build": "rm -fr dist/* && tsc -p tsconfig.json && tsc -p tsconfig-cjs.json && ./fixup.sh",
    "attw": "attw --pack",
    "publint": "publint --strict",
    "check": "npm run attw && npm run publint",
    "deploy": "npm run build && npm run check && npm publish --access=public"
  },
  "keywords": [
    "사업자등록번호",
    "주민등록번호",
    "법인등록번호",
    "외국인등록번호",
    "개인통관고유부호",
    "운전면허번호",
    "여권번호",
    "자동차등록번호",
    "BRN",
    "RRN",
    "CRN",
    "FRN",
    "PCC",
    "DLN",
    "passport",
    "VRN",
    "korean",
    "korea",
    "validation",
    "identifier"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyungseopk1m/korean-id.git"
  },
  "bugs": {
    "url": "https://github.com/kyungseopk1m/korean-id/issues",
    "email": "kks0919@kakao.com"
  },
  "homepage": "https://github.com/kyungseopk1m/korean-id",
  "author": "Kyungseop Kim <kks0919@kakao.com> (https://github.com/kyungseopk1m)",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@swc/core": "^1.15.24",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "publint": "^0.3.12",
    "typescript": "^6.0.2"
  },
  "bin": {
    "korean-id": "bin/korean-id.js"
  },
  "files": [
    "dist",
    "bin"
  ]
}
